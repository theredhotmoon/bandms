# Copy this to /opt/bandms/.env on the server and fill in all values.

# Application
APP_NAME=BandMS
APP_KEY=base64:GENERATE_WITH_openssl_rand_-base64_32
APP_URL=http://YOUR_SERVER_IP
APP_VERSION=latest

# Database
DB_DATABASE=bandms
DB_USERNAME=bandms
DB_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ANOTHER_STRONG_PASSWORD

# Drivers — database is fine for a single-server setup
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# Optional API integrations (leave blank to disable)
YOUTUBE_API_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
SETLISTFM_API_KEY=
