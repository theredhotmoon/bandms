---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ConcertCard from '@/components/ConcertCard.astro'
import ReleaseCard from '@/components/ReleaseCard.astro'
import PostCard from '@/components/PostCard.astro'
import MemberCard from '@/components/MemberCard.astro'
import SocialLinks from '@/components/SocialLinks.astro'
import NewsletterSignup from '@/components/NewsletterSignup.vue'
import { getBandProfile, getConcerts, getReleases, getPosts, getSocialLinks, getMembers } from '@/lib/cms'
import { isUpcoming } from '@/lib/i18n'

const [profile, concerts, releases, { data: posts }, socialLinks, members] = await Promise.all([
  getBandProfile('en'),
  getConcerts(),
  getReleases('en'),
  getPosts('en', 1),
  getSocialLinks(),
  getMembers(),
])

const upcoming = concerts.filter(c => isUpcoming(c.date)).slice(0, 3)
const latestReleases = releases.slice(0, 4)
const latestPosts = posts.slice(0, 3)
const currentMembers = members.filter(m => m.is_current)

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: profile.name,
  description: profile.bio_short,
  foundingDate: profile.formation_year?.toString(),
  homeLocation: profile.hometown ? { '@type': 'Place', name: profile.hometown } : undefined,
  genre: profile.genres?.split(',').map(g => g.trim()),
  url: Astro.site?.toString(),
  logo: profile.logo_url ?? undefined,
}
---

<BaseLayout
  title={profile.name}
  description={profile.bio_short ?? `${profile.name} — ${profile.genres ?? 'Ska & Reggae'} band`}
  structuredData={structuredData}
  bandName={profile.name}
>
  <!-- ── Hero ── -->
  <section class="relative flex min-h-[85vh] items-end pb-16 pt-24">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-[rgb(8,8,8)]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(255,180,0,0.08),_transparent_60%)]" />

    <div class="relative mx-auto w-full max-w-7xl px-4 sm:px-6">
      {profile.logo_url && (
        <img src={profile.logo_url} alt={profile.name} class="mb-8 h-16 object-contain" />
      )}
      <h1 class="text-5xl font-black text-white sm:text-7xl md:text-8xl leading-none tracking-tighter">
        {profile.name}
      </h1>
      {profile.genres && (
        <p class="mt-3 text-lg text-accent font-medium tracking-wide uppercase">
          {profile.genres}
        </p>
      )}
      {profile.bio_short && (
        <p class="mt-4 max-w-2xl text-lg text-zinc-400 leading-relaxed">
          {profile.bio_short}
        </p>
      )}

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/concerts" class="rounded-lg bg-accent px-6 py-3 font-bold text-black hover:bg-accent-dark transition-colors">
          See Shows
        </a>
        <a href="/releases" class="rounded-lg border border-border px-6 py-3 font-bold text-white hover:border-zinc-600 transition-colors">
          Our Music
        </a>
        {profile.booking_email && (
          <a href="/contact" class="rounded-lg border border-border px-6 py-3 font-bold text-zinc-400 hover:text-white hover:border-zinc-600 transition-colors">
            Book Us
          </a>
        )}
      </div>

      {socialLinks.length > 0 && (
        <div class="mt-8">
          <SocialLinks links={socialLinks} />
        </div>
      )}
    </div>
  </section>

  <!-- ── Upcoming Shows ── -->
  {upcoming.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 py-16">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <div class="accent-line mb-3" />
          <h2 class="text-2xl font-black text-white">Upcoming Shows</h2>
        </div>
        <a href="/concerts" class="text-sm text-accent hover:underline">All shows →</a>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {upcoming.map(c => <ConcertCard concert={c} />)}
      </div>
    </section>
  )}

  <!-- ── Latest Music ── -->
  {latestReleases.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 py-16">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <div class="accent-line mb-3" />
          <h2 class="text-2xl font-black text-white">Music</h2>
        </div>
        <a href="/releases" class="text-sm text-accent hover:underline">Discography →</a>
      </div>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        {latestReleases.map(r => <ReleaseCard release={r} />)}
      </div>
    </section>
  )}

  <!-- ── Band Members ── -->
  {currentMembers.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 py-16">
      <div class="mb-10 text-center">
        <div class="accent-line mx-auto mb-3" />
        <h2 class="text-2xl font-black text-white">The Band</h2>
      </div>
      <div class="flex flex-wrap justify-center gap-8 sm:gap-12">
        {currentMembers.map(m => <MemberCard member={m} />)}
      </div>
      <div class="mt-8 text-center">
        <a href="/about" class="text-sm text-accent hover:underline">Read our story →</a>
      </div>
    </section>
  )}

  <!-- ── Latest News ── -->
  {latestPosts.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 py-16">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <div class="accent-line mb-3" />
          <h2 class="text-2xl font-black text-white">News</h2>
        </div>
        <a href="/posts" class="text-sm text-accent hover:underline">All posts →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map(p => <PostCard post={p} />)}
      </div>
    </section>
  )}

  <!-- ── Newsletter ── -->
  <section class="bg-surface-2 border-y border-border py-16">
    <div class="mx-auto max-w-xl px-4 sm:px-6 text-center">
      <div class="accent-line mx-auto mb-4" />
      <h2 class="text-2xl font-black text-white mb-2">Stay in the loop</h2>
      <p class="text-zinc-400 mb-6">
        New shows, releases, and behind-the-scenes straight to your inbox.
      </p>
      <NewsletterSignup client:visible />
      <p class="mt-3 text-xs text-zinc-600">No spam. Unsubscribe any time.</p>
    </div>
  </section>
</BaseLayout>
