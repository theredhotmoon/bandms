---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PhotoLightbox from '@/components/PhotoLightbox.vue'
import { getAlbums, getBandProfile } from '@/lib/cms'
import { fmtDateShort } from '@/lib/i18n'

const [albums, profile] = await Promise.all([getAlbums(), getBandProfile('en')])

// Only published albums with at least one photo
const visible = albums.filter(a => a.published_at && a.photo_count > 0)
---

<BaseLayout
  title={`Photos — ${profile.name}`}
  description={`Photo gallery of ${profile.name} — concerts, behind the scenes, and more.`}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 pt-16 pb-24">
    <div class="mb-12">
      <div class="accent-line mb-4" />
      <h1 class="text-4xl font-black text-white sm:text-5xl">Photos</h1>
    </div>

    {visible.length === 0 && (
      <p class="text-zinc-500">No photos yet — check back soon.</p>
    )}

    {visible.map(album => (
      <section class="mb-14">
        <div class="flex items-baseline justify-between mb-4">
          <div>
            <h2 class="text-xl font-bold text-white">{album.title}</h2>
            {album.taken_at && (
              <p class="text-sm text-zinc-500 mt-0.5">{fmtDateShort(album.taken_at, 'en')}</p>
            )}
            {album.description && (
              <p class="text-sm text-zinc-400 mt-1">{album.description}</p>
            )}
          </div>
          <span class="text-xs text-zinc-600">{album.photo_count} photos</span>
        </div>

        <PhotoLightbox
          client:visible
          photos={(album.photos ?? []).map(p => ({ src: p.image_url ?? '', caption: p.caption }))}
        />
      </section>
    ))}
  </div>
</BaseLayout>
