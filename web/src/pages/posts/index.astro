---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostCard from '@/components/PostCard.astro'
import { getPosts, getBandProfile } from '@/lib/cms'

const [{ data: posts, meta }, profile] = await Promise.all([
  getPosts('en', 1),
  getBandProfile('en'),
])
---

<BaseLayout
  title={`News — ${profile.name}`}
  description={`News, updates, and stories from ${profile.name}.`}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 pt-16 pb-24">
    <div class="mb-12">
      <div class="accent-line mb-4" />
      <h1 class="text-4xl font-black text-white sm:text-5xl">News</h1>
    </div>

    {posts.length === 0 ? (
      <p class="text-zinc-500">No posts yet — check back soon.</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map(p => <PostCard post={p} />)}
      </div>
    )}

    {meta && meta.last_page > 1 && (
      <p class="mt-8 text-center text-sm text-zinc-600">
        Showing {posts.length} of {meta.total} posts — more pages coming soon.
      </p>
    )}
  </div>
</BaseLayout>
