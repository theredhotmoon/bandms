---
import BaseLayout from '@/layouts/BaseLayout.astro'
import AddToCart from '@/components/AddToCart.vue'
import { getShopItems, getShopItem, getBandProfile } from '@/lib/cms'

export async function getStaticPaths() {
  const items = await getShopItems()
  return items.map(i => ({ params: { slug: i.slug } }))
}

const { slug } = Astro.params
const [item, profile] = await Promise.all([
  getShopItem(slug!),
  getBandProfile('en'),
])

const images = item.photos.sort((a, b) => a.sort_order - b.sort_order)
const mainImage = images[0]?.url ?? item.cover_photo
---

<BaseLayout
  title={`${item.name} — ${profile.name} Merch`}
  description={item.description ?? `${item.name} — official merch from ${profile.name}`}
  image={mainImage}
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 pt-16 pb-24">
    <nav class="mb-8 text-sm text-zinc-600">
      <a href="/merch" class="hover:text-zinc-400 transition-colors">Merch</a>
      <span class="mx-2">›</span>
      <span class="text-zinc-400">{item.name}</span>
    </nav>

    <div class="grid gap-10 lg:grid-cols-2">
      <!-- Images -->
      <div class="space-y-3">
        {mainImage ? (
          <div class="overflow-hidden rounded-xl border border-border bg-zinc-900 aspect-square">
            <img src={mainImage} alt={item.name} loading="eager" class="w-full h-full object-cover" />
          </div>
        ) : (
          <div class="overflow-hidden rounded-xl border border-border bg-zinc-900 aspect-square flex items-center justify-center text-zinc-700">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
            </svg>
          </div>
        )}
        {images.length > 1 && (
          <div class="grid grid-cols-4 gap-2">
            {images.map(p => (
              <div class="overflow-hidden rounded-lg border border-border bg-zinc-900 aspect-square">
                <img src={p.url} alt={p.alt_text ?? item.name} loading="lazy" class="w-full h-full object-cover" />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Details -->
      <div>
        <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">{item.type}</p>
        <h1 class="text-3xl font-black text-white leading-tight">{item.name}</h1>

        {item.categories.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-2">
            {item.categories.map(c => (
              <span class="rounded-full bg-surface-2 px-2 py-0.5 text-xs text-zinc-500">{c.name}</span>
            ))}
          </div>
        )}

        <div class="mt-6">
          <AddToCart item={item} client:visible />
        </div>

        {item.description && (
          <div class="prose mt-8">
            {item.description.split('\n\n').map(p => <p>{p}</p>)}
          </div>
        )}

        {item.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {item.tags.map(t => (
              <span class="rounded-full bg-surface-2 px-2 py-0.5 text-xs text-zinc-500">#{t.name}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
