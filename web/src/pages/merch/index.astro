---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getShopItems, getShopCategories, getBandProfile } from '@/lib/cms'
import { formatPrice, preferredPrice } from '@/stores/cart'

const [items, categories, profile] = await Promise.all([
  getShopItems(),
  getShopCategories(),
  getBandProfile('en'),
])

const available = items.filter(i => i.is_available || i.is_presale)
---

<BaseLayout
  title={`Merch — ${profile.name}`}
  description={`Official merchandise from ${profile.name}. Records, apparel, and more.`}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 pt-16 pb-24">
    <div class="mb-12">
      <div class="accent-line mb-4" />
      <h1 class="text-4xl font-black text-white sm:text-5xl">Merch</h1>
    </div>

    {available.length === 0 ? (
      <div class="rounded-xl border border-border bg-surface p-10 text-center">
        <p class="text-lg text-zinc-400">No items available right now.</p>
        <p class="mt-1 text-sm text-zinc-600">Check back soon, or subscribe to the newsletter for updates.</p>
        <a href="/newsletter" class="mt-4 inline-block text-accent hover:underline text-sm">Subscribe →</a>
      </div>
    ) : (
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {available
          .sort((a, b) => a.sort_order - b.sort_order)
          .map(item => {
            const price = preferredPrice(item.prices)
            return (
              <a href={`/merch/${item.slug}`} class="group block overflow-hidden rounded-xl border border-border bg-surface hover:border-zinc-700 transition-all hover:-translate-y-0.5">
                <!-- Cover photo -->
                <div class="aspect-square overflow-hidden bg-zinc-900 relative">
                  {item.cover_photo ? (
                    <img
                      src={item.cover_photo}
                      alt={item.name}
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  ) : (
                    <div class="flex h-full items-center justify-center text-zinc-700">
                      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9l4-4 4 4 4-4 4 4"/>
                      </svg>
                    </div>
                  )}
                  {item.is_presale && (
                    <span class="absolute top-2 left-2 rounded-full bg-accent px-2 py-0.5 text-[10px] font-bold text-black">
                      PRE-ORDER
                    </span>
                  )}
                  {item.stock_quantity === 0 && !item.is_presale && (
                    <div class="absolute inset-0 bg-black/60 flex items-center justify-center">
                      <span class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Sold Out</span>
                    </div>
                  )}
                </div>
                <!-- Info -->
                <div class="p-3">
                  <p class="text-sm font-semibold text-white leading-snug group-hover:text-accent transition-colors line-clamp-2">
                    {item.name}
                  </p>
                  {price && (
                    <p class="mt-1 text-sm font-bold text-accent">{formatPrice(price)}</p>
                  )}
                </div>
              </a>
            )
          })}
      </div>
    )}
  </div>
</BaseLayout>
