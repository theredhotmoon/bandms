---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout title="Page not found" description="The page you're looking for doesn't exist." noindex={true}>
  <div class="mx-auto max-w-lg px-4 sm:px-6 py-32 text-center">
    <p class="text-8xl font-black text-zinc-800">404</p>
    <h1 class="mt-4 text-2xl font-black text-white">Page not found</h1>
    <p class="mt-2 text-zinc-500">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="mt-8 inline-block rounded-lg bg-accent px-6 py-3 font-bold text-black hover:bg-accent-dark transition-colors">
      Back to home
    </a>
  </div>
</BaseLayout>
