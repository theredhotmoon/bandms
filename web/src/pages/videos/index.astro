---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getMusicVideos, getBandProfile } from '@/lib/cms'
import { youtubeEmbedUrl, youtubeThumbnail, formatNumber, fmtDateShort } from '@/lib/i18n'

const [videos, profile] = await Promise.all([getMusicVideos(), getBandProfile('en')])
const sorted = [...videos].sort((a, b) => a.sort_order - b.sort_order)
---

<BaseLayout
  title={`Videos — ${profile.name}`}
  description={`Music videos by ${profile.name}. Watch on YouTube.`}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 pt-16 pb-24">
    <div class="mb-12">
      <div class="accent-line mb-4" />
      <h1 class="text-4xl font-black text-white sm:text-5xl">Videos</h1>
    </div>

    {sorted.length === 0 && (
      <p class="text-zinc-500">No videos yet — check back soon.</p>
    )}

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map(video => {
        const embedUrl = youtubeEmbedUrl(video.video_url)
        const thumb = video.og_image ?? youtubeThumbnail(video.video_url)
        return (
          <article class="overflow-hidden rounded-xl border border-border bg-surface">
            {embedUrl ? (
              <div class="relative aspect-video">
                <iframe
                  src={embedUrl}
                  title={video.title}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                  class="absolute inset-0 h-full w-full"
                />
              </div>
            ) : thumb ? (
              <a href={video.video_url} target="_blank" rel="noopener noreferrer" class="relative block aspect-video overflow-hidden bg-zinc-900">
                <img src={thumb} alt={video.title} loading="lazy" class="h-full w-full object-cover" />
                <div class="absolute inset-0 flex items-center justify-center bg-black/40">
                  <div class="flex h-14 w-14 items-center justify-center rounded-full bg-accent">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="black">
                      <polygon points="5 3 19 12 5 21 5 3"/>
                    </svg>
                  </div>
                </div>
              </a>
            ) : null}

            <div class="p-4">
              <h3 class="font-semibold text-white text-sm leading-snug">{video.title}</h3>
              <div class="mt-1 flex items-center gap-3 text-xs text-zinc-600">
                {video.published_at && <time datetime={video.published_at}>{fmtDateShort(video.published_at)}</time>}
                {video.view_count && <span>{formatNumber(video.view_count)} views</span>}
                {video.duration && <span>{video.duration}</span>}
              </div>
              {video.channel_name && <p class="mt-1 text-xs text-zinc-600">{video.channel_name}</p>}
            </div>
          </article>
        )
      })}
    </div>
  </div>
</BaseLayout>
