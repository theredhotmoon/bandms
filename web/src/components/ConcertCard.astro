---
import type { Concert } from '@/types/concert'
import { fmtDate, fmtTime, isUpcoming } from '@/lib/i18n'

export interface Props {
  concert: Concert
}

const { concert } = Astro.props
const upcoming = isUpcoming(concert.date)
---

<article class="group flex gap-4 rounded-xl border border-border bg-surface hover:border-zinc-700 transition-colors p-4">
  <!-- Date block -->
  <div class="flex-none text-center min-w-14">
    <div class="text-2xl font-black text-accent leading-none">
      {new Date(concert.date).getDate()}
    </div>
    <div class="text-xs text-zinc-500 uppercase tracking-wide mt-0.5">
      {new Date(concert.date).toLocaleDateString('en-GB', { month: 'short' })}
    </div>
    <div class="text-xs text-zinc-600">
      {new Date(concert.date).getFullYear()}
    </div>
  </div>

  <!-- Details -->
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2">
      <div>
        <p class="font-semibold text-white leading-tight">
          {concert.venue.name}
        </p>
        {concert.venue.city && (
          <p class="text-sm text-zinc-400">
            {concert.venue.city}{concert.venue.country && `, ${concert.venue.country}`}
          </p>
        )}
      </div>
      {upcoming ? (
        <span class="shrink-0 rounded-full bg-accent/10 px-2 py-0.5 text-xs font-medium text-accent">
          Upcoming
        </span>
      ) : (
        <span class="shrink-0 rounded-full bg-zinc-800 px-2 py-0.5 text-xs text-zinc-500">
          Past
        </span>
      )}
    </div>

    {concert.start_time && (
      <p class="mt-1 text-xs text-zinc-600">{fmtTime(concert.start_time)}</p>
    )}

    {concert.bands.length > 1 && (
      <p class="mt-1 text-xs text-zinc-500">
        {concert.bands.map(b => b.name).join(' · ')}
      </p>
    )}
  </div>

  <!-- Arrow -->
  <a
    href={`/concerts/${concert.slug_en}`}
    class="flex-none self-center text-zinc-700 group-hover:text-accent transition-colors"
    aria-label={`Details for concert on ${fmtDate(concert.date, 'en')}`}
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>
</article>
