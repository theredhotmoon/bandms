---
import MobileNav from './MobileNav.vue'
import CartIcon from './CartIcon.vue'

const links = [
  { href: '/concerts', label: 'Shows' },
  { href: '/releases', label: 'Music' },
  { href: '/posts',    label: 'News' },
  { href: '/photos',   label: 'Photos' },
  { href: '/videos',   label: 'Videos' },
  { href: '/press',    label: 'Press' },
  { href: '/merch',    label: 'Merch' },
  { href: '/epk',      label: 'EPK' },
  { href: '/contact',  label: 'Contact' },
]

const current = Astro.url.pathname
---

<header class="sticky top-0 z-40 border-b border-border bg-[rgb(8,8,8)/90] backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <!-- Logo / band name -->
    <a href="/" class="text-xl font-black tracking-tight text-white hover:text-accent transition-colors shrink-0">
      Skanking Storks
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors',
            current.startsWith(href)
              ? 'text-accent'
              : 'text-zinc-400 hover:text-white',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Right side actions -->
    <div class="flex items-center gap-3">
      <CartIcon client:idle />
      <!-- Mobile hamburger -->
      <MobileNav links={links} client:idle />
    </div>
  </div>
</header>
