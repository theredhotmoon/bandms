---
import { getSiteConfig } from '@/lib/cms'
import MobileNav from './MobileNav.vue'
import CartIcon from './CartIcon.vue'

const siteConfig = await getSiteConfig()

const allLinks = [
  { href: '/concerts', label: 'Shows',   module: 'concerts' },
  { href: '/releases', label: 'Music',   module: 'releases' },
  { href: '/posts',    label: 'News',    module: 'posts'    },
  { href: '/photos',   label: 'Photos',  module: 'photos'   },
  { href: '/videos',   label: 'Videos',  module: 'videos'   },
  { href: '/press',    label: 'Press',   module: 'press'    },
  { href: '/merch',    label: 'Shop',    module: 'merch'    },
  { href: '/epk',      label: 'EPK',     module: 'epk'      },
  { href: '/contact',  label: 'Contact', module: null       },
]

// module === null means always show; module === false (explicit) means hide
const links = allLinks.filter(l => l.module === null || siteConfig.modules[l.module] !== false)

const current = Astro.url.pathname
---

<header class="ss-header">
  <div class="ss-header-inner">
    <a href="/" class="ss-logo">Skanking Storks</a>

    <nav class="ss-desktop-nav" aria-label="Main navigation">
      {links.map(({ href, label }) => (
        current.startsWith(href)
          ? <span class="ss-nav-link is-active" aria-current="page">{label}</span>
          : <a href={href} class="ss-nav-link">{label}</a>
      ))}
    </nav>

    <div class="ss-header-right">
      <CartIcon client:idle />
      <MobileNav links={links} client:idle />
    </div>
  </div>
</header>

<style>
  .ss-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: #121212;
    color: #EFE7D6;
  }
  .ss-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 20px 90px;
    flex-wrap: nowrap;
  }

  .ss-logo {
    font-family: 'Anton', 'Impact', sans-serif;
    font-size: 22px;
    line-height: 1;
    color: #EFE7D6;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color .12s;
  }
  .ss-logo:hover { color: #1F8F7A; }

  .ss-desktop-nav {
    display: none;
    align-items: center;
    gap: 20px;
    font-family: 'Archivo', system-ui, sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 1;
    letter-spacing: .08em;
    text-transform: uppercase;
    flex: 1;
    justify-content: flex-end;
  }
  @media (min-width: 1024px) {
    .ss-desktop-nav { display: flex; }
  }

  .ss-nav-link {
    color: #EFE7D6;
    text-decoration: none;
    white-space: nowrap;
    transition: color .12s;
    cursor: pointer;
  }
  a.ss-nav-link:hover { color: rgba(239,231,214,.55); }
  span.ss-nav-link.is-active { color: #1F8F7A; }

  .ss-header-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  @media (max-width: 1100px) {
    .ss-header-inner { padding: 20px 40px; }
  }
  @media (max-width: 600px) {
    .ss-header-inner { padding: 18px 20px; }
    .ss-logo { font-size: 18px; }
  }
</style>
