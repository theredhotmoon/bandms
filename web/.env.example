# Base URL the Astro build uses to reach the CMS API.
# In Docker this is the container name; locally use the frontend proxy port.
API_BASE=http://localhost:80

# Proxy target for `pnpm dev` (same as API_BASE for local dev).
API_PROXY=http://localhost:80

# Canonical site URL — used for sitemap.xml and OG canonical tags.
SITE_URL=https://skanking-storks.com
