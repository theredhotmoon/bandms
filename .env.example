# ── App ───────────────────────────────────────────────────────────────────────
# Generate with: docker compose run --rm backend php artisan key:generate --show
APP_KEY=base64:CHANGE_ME

# Public URL of the application (used by Laravel for link generation)
APP_URL=http://localhost

# ── Database ──────────────────────────────────────────────────────────────────
DB_DATABASE=bandms
DB_USERNAME=bandms
DB_PASSWORD=secret

# ── Ports (host) ──────────────────────────────────────────────────────────────
# Port exposed on your host machine → maps to frontend container port 80
FRONTEND_PORT=80
