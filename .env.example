# ── App ───────────────────────────────────────────────────────────────────────
# Generate with: docker compose run --rm backend php artisan key:generate --show
APP_KEY=base64:CHANGE_ME

# Public URL of the application (used by Laravel for link generation)
APP_URL=http://localhost

# ── Database ──────────────────────────────────────────────────────────────────
DB_DATABASE=bandms
DB_USERNAME=bandms
DB_PASSWORD=secret

# ── Ports (host) ──────────────────────────────────────────────────────────────
# Port exposed on your host machine → maps to frontend container port 80
FRONTEND_PORT=80

# ── Mail ──────────────────────────────────────────────────────────────────────
# Defaults to "log" — emails are written to storage/logs/laravel.log.
# Set to "smtp" (or "ses", "mailgun", etc.) to actually send emails.
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Newsletter ────────────────────────────────────────────────────────────────
# Public URL of the frontend — used to build links in confirmation emails.
# In production set this to your actual domain, e.g. https://yourbandname.com
FRONTEND_URL=http://localhost

# Set to "false" to skip MX/DNS validation (useful for local dev with fake emails)
NEWSLETTER_VERIFY_MX=true
