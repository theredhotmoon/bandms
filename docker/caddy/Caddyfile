# Production Caddy config.
#
# Replace ":80" with your domain name to enable automatic HTTPS:
#   yourdomain.com {
#       ...
#   }
#
# Routing:
#   /api/*         → Laravel backend
#   /storage/*     → Laravel backend (uploaded files)
#   /admin*        → Vue SPA (admin panel)
#   /login         → Vue SPA
#   /*             → Astro public site

:80 {
    # ── Backend API ──────────────────────────────────────────────────────────
    handle /api/* {
        reverse_proxy backend:80
    }

    # ── Storage (uploaded media served by Laravel) ───────────────────────────
    handle /storage/* {
        reverse_proxy backend:80
    }

    # ── Vue SPA — admin panel and login ──────────────────────────────────────
    handle /admin* {
        reverse_proxy frontend:80
    }
    handle /login {
        reverse_proxy frontend:80
    }

    # ── Astro public site — everything else ───────────────────────────────────
    handle {
        reverse_proxy web:80
    }
}
